<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet">
    <title>Plant Bud</title>

    <script>
        module.exports = {
            theme: {
                extend: {
                    fontFamily: {
                        poppins: ['Poppins', 'sans-serif'],
                    },
                },
            },
        }
    </script>
</head>

<body class="bg-[#6C8E6B] m-0 p-0">

    <!-- Header -->
    <header class="relative">
        <div>
            <img src="resources/images/welcome/header.png" alt="" class="w-full block">

            <div
                class="absolute top-[75%] left-[75%] transform -translate-x-1/2 -translate-y-1/2 flex items-center justify-center">
                <div class="absolute w-full h-full bg-[#D9D9D9] rounded-full"></div>
                <img src="resources/images/essential/logo.png" alt="" class="w-[600px] relative z-10">
            </div>
        </div>
    </header>

    <!-- Contenido -->
    <div class="flex flex-col justify-center pt-7 w-full max-w-5xl mx-auto px-20">
        <h1 class="text-white text-7xl font-bold text-left drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">
            Grow <span class="text-[#1E3D19]">Plants</span> for
        </h1>

        <h1 class="text-white text-7xl font-bold text-right drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">
            a Better life!
        </h1>
    </div>

    <div class="mt-20 flex justify-center">
        <div
            class="relative bg-[#D5DCD4] py-7 px-20 w-full max-w-5xl rounded-lg drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">

            <img src="resources/images/welcome/first-icon.png" class="absolute -top-10 left-20 w-40">

            <h2 class="font-poppins font-bold text-4xl text-right pb-3 tracking-wide">
                What is Plant Bud?
            </h2>

            <p class="font-poppins text-[#728B6F] text-right font-semibold tracking-wide text-lg leading-tight">
                <span class="text-[#1E3D19]">Plant Bud</span> is a web site
                in wihich not only you learn about <span class="text-[#1E3D19]">plants</span> <br>
                <span class="text-[#1E3D19]">carement</span>, but also you have access to <span
                    class="text-[#1E3D19]">profesional services</span> of <span class="text-[#1E3D19]">garden</span>
                <br>
                <span class="text-[#1E3D19]">maintance</span>, encouraging you to <span class="text-[#1E3D19]">grow
                    plants</span> in your home or <br>
                workplace, marketing it a more <span class="text-[#1E3D19]">beautiful and healthy</span> space.
            </p>

        </div>
    </div>

    <div class="mt-40">
            <div class="flex flex-col justify-center w-full max-w-5xl mx-auto px-20">
        <h1 class="text-[#1E3D19] text-7xl font-bold text-left drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">
            Benefits that
        </h1>

        <h1 class="text-white text-7xl font-bold text-right drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">
            Plant Bud <span class="text-[#1E3D19]">offers you</span>
        </h1>
    </div>
    </div>
</body>

</html>