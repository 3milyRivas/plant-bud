<!DOCTYPE html>
<html lang="en-us">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    Plant bud
  </title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
  @stack('dumper')
</head>

<body
  class="bg-[#6C8E6B] bg-[radial-gradient(circle_at_20%_20%,rgba(237,231,214,0.25)_0%,transparent_60%),radial-gradient(circle_at_80%_80%,rgba(217,217,217,0.2)_0%,transparent_60%)]">

  <div class="bg-green-800">
    <div class="flex justify-between items-center px-10 py-6 text-white">
      <div class="flex items-center gap-2">
        <div class="bg-green-800 px-3 py-2 rounded-full font-semibold text-sm">
          Plant<br />BUD
        </div>
      </div>

      <p class="italic text-sm">
        "Plants make better life"
      </p>


    </div>

    <hr class="border-white border-opacity-40 mx-10" />


    <div class="pt-8 flex-grow flex items-center justify-center text-white">
      <h1 class="text-6xl font-extrabold tracking-wide">
        Plant-Bud
      </h1>
    </div>


    <div class="pt-12 px-6 pb-10">
      <div class="flex justify-between bg-white bg-opacity-90 rounded-2xl shadow-xl overflow-hidden">
        <div class="flex flex-col items-center text-center p-6 text-green-900">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <h3 class="font-bold text-lg">Plants</h3>
          <p class="text-sm italic">
            "Not all the plants need the same conditions"
          </p>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <div class="flex flex-col items-center text-center p-6 text-green-900">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <h3 class="font-bold text-lg">Community</h3>
          <p class="text-sm italic">
            "Keep on track of other people gardens"
          </p>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <div class="flex flex-col items-center text-center p-6 text-green-900">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <h3 class="font-bold text-lg">Maintenance</h3>
          <p class="text-sm italic">
            "Maintain your garden to keep it alive"
          </p>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <div class="flex flex-col items-center text-center p-6 text-green-900">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <h3 class="font-bold text-lg">Plant nursery</h3>
          <p class="text-sm italic">
            "Find your new bud in our listed shops"
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-center text-white pt-15">
    <div class="order-first text-center text-lg p">
      <h3 class="font-bold text-[25px]">Welcome to Plant Bud</h3>
      <p class="text-lg">We as a team are proud</p>
      <p class="text-lg">to offer you the best experience</p>
      <p class="text-lg">on the maintenance and care of plants.</p>
    </div>
    <div class="order-last pl-15">
      <img src="resources/images/logo.png" alt="logo" class="absolute-bottom-22">
    </div>
  </div>


  </section>





</body>

</html>
