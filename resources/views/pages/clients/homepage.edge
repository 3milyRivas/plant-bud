<!DOCTYPE html>
<html lang="en-us">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    Plant bud
  </title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
  @stack('dumper')
</head>

<body
  class="bg-[#6C8E6B] bg-[radial-gradient(circle_at_20%_20%,rgba(237,231,214,0.25)_0%,transparent_60%),radial-gradient(circle_at_80%_80%,rgba(217,217,217,0.2)_0%,transparent_60%)]">

  <div class="bg-[url('/assets/resources/images/bg-homepage.png')] bg-cover bg-center text-white">
    <div class="flex justify-between items-center px-10 py-6 text-white">
      <div class="flex items-center gap-2">
        <div class="bg-green-800 px-3 py-2 rounded-full font-semibold text-sm">
          Plant<br />BUD
        </div>
      </div>
      <p class="italic text-sm">
        "Plants make better life"
      </p>
    </div>
    <hr class="mx-10 border-t-4 border-white border-opacity-40" />
    <div class="pt-8 flex-grow flex items-center justify-center text-white">
      <h1 class="text-6xl font-extrabold tracking-wide">
        Plant-Bud
      </h1>
    </div>

    <!--Características tío-->
    <div class="mx-auto max-w-7xl px-6 pb-20 pt-12">
      <div class="flex bg-white bg-opacity-90 rounded-2xl shadow-xl overflow-hidden text-green-900">

        <!--Característica número uno tío-->
        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <div class="font-bold text-lg">Plants</div>
          <div class="text-sm italic">
            "Not all the plants need the same conditions"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número dos tío-->
        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <div class="font-bold text-lg">Community</div>
          <div class="text-sm italic">
            "Keep on track of other people gardens"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número tres tío-->

        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <div class="font-bold text-lg">Maintenance</div>
          <div class="text-sm italic">
            "Maintain your garden to keep it alive"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número cuatro tío-->

        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3"></div>
          <div class="font-bold text-lg">Plant nursery</div>
          <div class="text-sm italic">
            "Find your new bud in our listed shops"
          </div>
        </div>


      </div>
    </div>

  </div>

  <div class="mx-auto max-w-7xl px-14 py-16 flex items-center justify-center">
    <div class="max-w-md text-white">
      <div class="text-6xl font-semibold">
        Welcome to Plant‑Bud
      </div>

      <div class="mt-3 text-2xl leading-relaxed opacity-90">
        We as a team are proud to offer you the best experience
        on the maintenance and care of plants.
      </div>
    </div>
    <div class="flex h-32 w-32 items-center justify-center rounded-full bg-green-900 text-white">
      <img src="resources/images/essential/logo.png" class="">
    </div>
  </div>


</body>

</html>
