<!DOCTYPE html>
<html lang="en-us">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    Plant bud
  </title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
  @stack('dumper')
</head>

<body
  class="bg-[#6C8E6B] bg-[radial-gradient(circle_at_20%_20%,rgba(237,231,214,0.25)_0%,transparent_60%),radial-gradient(circle_at_80%_80%,rgba(217,217,217,0.2)_0%,transparent_60%)]">


  <div class="bg-[url('/assets/resources/images/bg-homepage.png')] bg-cover bg-center text-white">
    <div class="flex justify-between items-center px-10 py-6 text-white">
      <div class="flex items-center gap-2">
        <div class="bg-green-800 px-3 py-2 rounded-full font-semibold text-lg">
          Plant<br />BUD
        </div>
      </div>
      <p class="italic text-xl">
        "Plants make better life"
      </p>
    </div>
    <hr class="mx-10 border-t-4 border-white border-opacity-40" />
    <div class="pt-8 flex-grow flex items-center justify-center text-white">
      <h1 class="text-6xl font-extrabold tracking-wide">
        Plant-Bud
      </h1>
    </div>

    <!--Características tío-->
    <div class="mx-auto max-w-7xl px-6 pb-20 pt-12">
      <div class="flex bg-white bg-opacity-90 rounded-2xl shadow-xl overflow-hidden text-green-900">

        <!--Característica número uno tío-->
        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3 h-12 w-12"></div>
          <div class="font-bold text-2xl">Plants</div>
          <div class="text-xl italic">
            "Not all the plants need the same conditions"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número dos tío-->
        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3 h-12 w-12"></div>
          <div class="font-bold text-2xl">Community</div>
          <div class="text-xl italic">
            "Keep on track of other people gardens"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número tres tío-->

        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3 h-12 w-12"></div>
          <div class="font-bold text-2xl">Maintenance</div>
          <div class="text-xl italic">
            "Maintain your garden to keep it alive"
          </div>
        </div>

        <div class="hidden md:block w-px bg-green-900 bg-opacity-20"></div>

        <!--Característica número cuatro tío-->

        <div class="flex flex-col items-center text-center p-6 flex-1">
          <div class="bg-green-900 text-white p-3 rounded-full mb-3 h-12 w-12"></div>
          <div class="font-bold text-2xl">Plant nursery</div>
          <div class="text-xl italic">
            "Find your new bud in our listed shops"
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="mx-auto max-w-7xl px-14 py-16 flex items-center justify-center">
    <div class="max-w-md text-white">
      <div class="text-6xl font-semibold">
        Welcome to Plant‑Bud
      </div>

      <div class="mt-3 text-2xl leading-relaxed opacity-90">
        We as a team are proud to offer you the best experience
        on the maintenance and care of plants.
      </div>
    </div>
    <div class="pl-15 flex items-center justify-center">
      <img src="resources/images/essential/logo.png" class="h-82 w-80">
    </div>
  </div>
  <div class="bg-green-900">
    <div class="mx-auto max-w-7xl px-10 py-20">
      <div class="flex items-center justify-between text-white">

        <!-- Pulgar arriba -->
        <div class="flex flex-1 flex-col items-center text-center">
          <div class="mb-4 text-8xl">👍</div>
          <div class="text-2xl font-medium opacity-95">
            A great experience
          </div>
        </div>


        <div class="h-35 w-1 bg-white bg-opacity-50"></div>

        <!-- Tarjeta de crédito chavales -->
        <div class="flex flex-1 flex-col items-center text-center">
          <div class="mb-4 text-8xl">💳</div>
          <div class="text-2xl font-medium opacity-95">
            Safe payment
          </div>
        </div>


        <div class="h-35 w-1 bg-white bg-opacity-50"></div>

        <!-- Corazón tío -->
        <div class="flex flex-1 flex-col items-center text-center">
          <div class="mb-4 text-8xl">🤍</div>
          <div class="text-2xl font-medium opacity-95">
            Friendly Services
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="bg-[#7f9a7a] py-20">


    <div class="text-center mb-12">
      <div class="text-white text-3xl font-bold">
        Most popular plants
      </div>
    </div>

    <div class="mx-auto max-w-5xl px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10">

        <!-- CARD -->
        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-1.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-2.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-3.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-4.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-5.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-6.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-7.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-8.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-2xl bg-white p-4 shadow-lg">
            <div class="h-36 w-36 rounded-xl bg-[url('/assets/resources/images/plant-9.jpg')] bg-cover bg-center"></div>
          </div>
        </div>

      </div>
    </div>


    <div class="mt-16">
      <div class="mx-auto max-w-6xl border-t-8 border-green-900 border-opacity-90 mb-12"></div>
      <div class="text-center text-white text-3xl font-bold">
        Start taking care of your<br />own plants
      </div>
    </div>
    <div class="bg-[#7f9a7a] py-20">

      <!-- TITLE -->
      <div class="text-center mb-10">
        <div class="text-green-900 text-2xl font-semibold">
          The right solution for the care of green and smart plants
        </div>
      </div>

      <!-- CARD -->
      <div class="mx-auto max-w-6xl px-6">
        <div class="bg-[#c9d2c4] rounded-3xl px-10 py-12">

          <div class="flex items-start justify-between text-center text-green-900">

            <!-- ITEM 1 -->
            <div class="flex flex-col items-center flex-1 px-4">
              <div class="text-6xl mb-4">💧</div>
              <div class="font-semibold text-lg mb-2">
                Humidity control
              </div>
              <div class="text-base opacity-80 leading-relaxed">
                Effective humidity control will keep it alive
              </div>
            </div>

            <!-- ITEM 2 -->
            <div class="flex flex-col items-center flex-1 px-4">
              <div class="text-6xl mb-4">🪲</div>
              <div class="font-semibold text-lg mb-2">
                Pest anticipation
              </div>
              <div class="text-base opacity-80 leading-relaxed">
                Save your plants from pests trying to kill it
              </div>
            </div>

            <!-- ITEM 3 -->
            <div class="flex flex-col items-center flex-1 px-4">
              <div class="text-6xl mb-4">🌱</div>
              <div class="font-semibold text-lg mb-2">
                Fertilize it
              </div>
              <div class="text-base opacity-80 leading-relaxed">
                Give your plants enough nutrients to be healthy
              </div>
            </div>

            <!-- ITEM 4 -->
            <div class="flex flex-col items-center flex-1 px-4">
              <div class="text-6xl mb-4">✂️</div>
              <div class="font-semibold text-lg mb-2">
                Pruning weeds
              </div>
              <div class="text-base opacity-80 leading-relaxed">
                Take care of the unwanted plants grow
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

</body>

</html>
