<!DOCTYPE html>
<html lang="en-us">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    Plant bud
  </title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
  @stack('dumper')
</head>


<body class="min-h-screen bg-[#7f9a7a] font-sans">


  <div class="relative h-[300px] bg-[url('/images/plants-bg.jpg')] bg-cover bg-center px-10 py-6">
    <div class="flex items-center justify-between">


      <div class="flex items-center gap-4">
        <div
          class="flex h-14 w-14 flex-col items-center justify-center rounded-full bg-green-900 text-xs font-bold text-white">
          <span>Plant</span>
          <span>BUD</span>
        </div>

        <div class="rounded-full bg-white/70 px-6 py-2 text-sm font-semibold">
          Back
        </div>
      </div>


      <div class="flex w-72 items-center rounded-full bg-white/80 px-4 py-2">
        <input type="text" placeholder="Search" class="w-full bg-transparent text-sm outline-none" />
      </div>

      <!-- USER -->
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/70">
        👤
      </div>

    </div>
  </div>


  <div class="-mt-24 px-10">
    <div class="flex items-center justify-between gap-10 rounded-2xl bg-[#d7d4d3] p-10">

      <div class="max-w-lg">
        <div class="text-4xl font-bold leading-tight text-black">
          Pick up the plants you’ve been dreaming of !
        </div>

        <div class="mt-4 text-sm text-gray-700">
          Look all the plants stores we offer
        </div>

        <div class="mt-6 inline-block rounded-full bg-green-900 px-10 py-2 text-sm font-semibold text-white">
          Contact
        </div>
      </div>



    </div>
  </div>

  <!-- BOTTOM TEXT -->
  <div class="mt-20 pb-10">
    <div class="mx-auto max-w-md text-center text-sm text-white">
      A jubilation brought by the purchase of another new form of life
    </div>
  </div>


</body>


</html>
